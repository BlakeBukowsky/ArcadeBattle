# Resend (https://resend.com) — for sending magic-link sign-in emails
RESEND_API_KEY=
# In dev you can use onboarding@resend.dev (only sends to your own Resend account email).
# In production, use a verified domain: noreply@yourdomain.com
RESEND_FROM=onboarding@resend.dev

# JWT secret - any random string
JWT_SECRET=change-me-to-something-random

# URLs (defaults work for local dev)
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001
